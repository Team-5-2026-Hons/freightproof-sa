# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Supabase (dev only)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# Hedera
HEDERA_ACCOUNT_ID=0.0.xxxxxx
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=testnet
HEDERA_TOPIC_ID=
HEDERA_SUBMIT_TIMEOUT_SECONDS=15.0

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Supabase Auth
# JWT_SECRET: Supabase dashboard → Settings → API → JWT Secret
# SERVICE_ROLE_KEY: Supabase dashboard → Settings → API → service_role key
SUPABASE_JWT_SECRET=
SUPABASE_SERVICE_ROLE_KEY=

# Integration mock toggles (true = use mock, false = call real API)
IDVS_USE_MOCK=true
IDVS_API_KEY=
IDVS_API_URL=
PULSE_USE_MOCK=true
PULSE_API_KEY=
PULSE_API_URL=
PP_USE_MOCK=true
PP_API_KEY=
PP_API_PASSWORD=
PP_API_URL=
PP_POLL_INTERVAL_SECONDS=60

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
S3_BUCKET_NAME=

# Runtime config
GPS_TOLERANCE_METRES=50
DEMO_MODE=false

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
