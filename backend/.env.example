# Database
DATABASE_URL=postgresql+asyncpg://postgres:password@db.xxxx.supabase.co:5432/postgres

# Redis
REDIS_URL=redis://localhost:6379

# Supabase (dev only)
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=

# Hedera
HEDERA_ACCOUNT_ID=0.0.xxxxxx
HEDERA_PRIVATE_KEY=
HEDERA_NETWORK=testnet
HEDERA_TOPIC_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# SendGrid
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# Auth
JWT_SECRET_KEY=
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_REFRESH_TOKEN_EXPIRE_HOURS=24

# Integration mock toggles (true = use mock, false = call real API)
IDVS_USE_MOCK=true
IDVS_API_KEY=
IDVS_API_URL=
PULSE_USE_MOCK=true
PULSE_API_KEY=
PULSE_API_URL=
PP_USE_MOCK=true
PP_API_KEY=
PP_API_URL=
PP_POLL_INTERVAL_SECONDS=60

# AWS / S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=af-south-1
S3_BUCKET_NAME=

# Runtime config
GPS_TOLERANCE_METRES=50
DEMO_MODE=false

# App
ENVIRONMENT=development
ALLOWED_ORIGINS=["http://localhost:3000","http://localhost:3001"]
