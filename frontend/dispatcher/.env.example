# FreightProof Dispatcher — required environment variables
# Copy this file to .env.local and fill in the values.

# FastAPI backend base URL (no trailing slash)
NEXT_PUBLIC_API_URL=http://localhost:8000

# Supabase project credentials
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Hedera HashScan base URL (defaults to testnet if not set)
NEXT_PUBLIC_HEDERA_HASHSCAN_BASE=https://hashscan.io/testnet

# Dev-only credentials for /dev/tokens page
NEXT_PUBLIC_DEV_EMAIL=
NEXT_PUBLIC_DEV_PASSWORD=
